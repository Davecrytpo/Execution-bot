{
  "name": "solana-telegram-execution-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start:api": "node dist/index.js",
    "start:bot": "node dist/bot/telegramBot.js",
    "start:worker": "node dist/workers/executor.js",
    "start:monitor": "node dist/workers/monitor.js",
    "start:sniper": "node dist/workers/sniper.js",
    "migrate": "node dist/scripts/migrate.js",
    "test": "node dist/tests/runTests.js",
    "test:smoke": "node dist/tests/smokeDryRun.js"
  },
  "dependencies": {
    "@solana/web3.js": "^1.95.4",
    "axios": "^1.9.0",
    "bs58": "^6.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "pg": "^8.13.1",
    "pino": "^9.7.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "@types/pg": "^8.11.10",
    "typescript": "^5.6.3"
  }
}
